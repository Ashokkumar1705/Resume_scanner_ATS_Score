{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "ResumeAnalysis": {
      "title": "Resume Analysis",
      "description": "Result of an AI resume analysis",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner's UID" },
        "content": { "type": "string", "description": "Original resume text" },
        "score": { "type": "number" },
        "analysis": {
          "type": "object",
          "properties": {
            "summary": { "type": "string" },
            "strengths": { "type": "array", "items": { "type": "string" } },
            "weaknesses": { "type": "array", "items": { "type": "string" } },
            "suggestions": { "type": "array", "items": { "type": "string" } }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "score", "analysis", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/resumes/{resumeId}": {
      "schema": "ResumeAnalysis",
      "description": "Resume analysis reports"
    }
  }
}
