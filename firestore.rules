rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - createdAt: timestamp (required)
    //
    // Collection: resumes
    // Document ID: {resumeId}
    // Fields:
    //   - userId: string (required)
    //   - content: string (required, max 10000 chars)
    //   - score: number (required, 0-100)
    //   - analysis: map (required)
    //     - summary: string
    //     - strengths: list<string>
    //     - weaknesses: list<string>
    //     - suggestions: list<string>
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 255 &&
             data.createdAt is timestamp;
    }

    function isValidResume(data) {
      return data.keys().hasAll(['userId', 'content', 'score', 'analysis', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.content is string && data.content.size() < 10000 &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             data.analysis is map &&
             data.analysis.summary is string && data.analysis.summary.size() < 2000 &&
             (!('optimizedContent' in data.analysis) || (data.analysis.optimizedContent is string && data.analysis.optimizedContent.size() < 15000)) &&
             data.createdAt is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.createdAt == resource.data.createdAt;
    }

    match /resumes/{resumeId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidResume(request.resource.data);
      allow delete: if isDocOwner();
      allow update: if isDocOwner() && isValidResume(request.resource.data);
    }
  }
}
